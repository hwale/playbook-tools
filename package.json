{
  "name": "playbook-tools",
  "private": true,
  "scripts": {
    "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "dev:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build",
    "dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "prod": "docker compose up -d",
    "prod:build": "docker compose up -d --build",
    "prod:down": "docker compose down",
    "logs": "docker compose logs -f --tail=200",
    "ps": "docker compose ps"
  }
}