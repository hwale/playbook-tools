# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

ENVIRONMENT=local
LOG_LEVEL=debug
APP_NAME=Playbook Tools API

# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Random secret used to sign JWTs. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Never share or commit this value.
SECRET_KEY=change-me-in-production-use-secrets-token-hex-32

# Where uploaded PDFs and the vector index are stored (inside the container).
# The docker-compose volume maps ./.data on your host to /repo/.data in the container.
DATA_DIR=/repo/.data

# Comma-separated list of allowed CORS origins.
# Add your prod domain here when deploying, e.g. https://yourdomain.com
CORS_ORIGINS=["http://localhost:5173","http://localhost"]

# Postgres connection string.
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# The +asyncpg driver prefix is required for async SQLAlchemy.
# In Docker, HOST is the service name "postgres" (Docker's internal DNS).
# Locally (outside Docker), HOST is "localhost" if you expose port 5432.
DATABASE_URL=postgresql+asyncpg://playbook:playbook@postgres:5432/playbook
